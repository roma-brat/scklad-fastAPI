# ============================================
# .dockerignore — Исключения для Docker сборки
# ============================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
.venv/
.env
.env.*
!.env.production.example

# Node.js (если есть frontend сборка)
node_modules/

# Git
.git/
.gitignore

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Docker файлы (не нужны внутри образа)
Dockerfile*
docker-compose*.yml
.docker/

# Тесты
.pytest_cache/
.coverage
htmlcov/
*.test.py

# Документация
*.md
!requirements.txt  # нужен для сборки

# Логи
*.log
logs/

# Бэкапы
backups/
*.bak

# Временные файлы
.DS_Store
Thumbs.db
*.tmp
*.temp

# Скриншоты (если есть)
*.png
*.jpg
!static/images/*.png
!static/images/*.jpg

# Локальные служебные файлы
sklad.db
*.db
