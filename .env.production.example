# ============================================
# .env.production — Настройки для продакшена
# ============================================
# Скопируйте в .env.production и заполните значения:
#   cp .env.production.example .env.production
# ============================================

# ===========================================
# БАЗА ДАННЫХ POSTGRESQL
# ===========================================
DB_NAME=sklad_db
DB_USER=sklad_user
# ВАЖНО: Измените пароль на сложный!
DB_PASSWORD=CHANGE_ME_to_secure_password_123
DB_PORT=5432

# ===========================================
# ПРИЛОЖЕНИЕ
# ===========================================
APP_PORT=8551
TIMEZONE=Europe/Moscow

# ===========================================
# БЕЗОПАСНОСТЬ
# ===========================================
# Сгенерируйте командой:
#   openssl rand -hex 32
SECRET_KEY=CHANGE_ME_generate_with_openssl_rands-hex_32

# ===========================================
# ЛОГИРОВАНИЕ
# ===========================================
LOG_LEVEL=INFO

# ===========================================
# GOOGLE SHEETS (опционально)
# ===========================================
# GOOGLE_CREDENTIALS_PATH=/app/service_account.json
# GOOGLE_SPREADSHEET_ID=
# GOOGLE_PLAN_CHEH=
